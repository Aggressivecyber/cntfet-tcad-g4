}

eDensityGradient:
{
    mx = 0.05
    my = 0.05
    mz = 0.05
    gamma_0 = 1.0
}

hDensityGradient:
{
    mx = 0.05
    my = 0.05
    mz = 0.05
    gamma_0 = 1.0
}

Scharfetter * relation and trap level for SRH recombination:
{
    taumin  = 1.0e-12 , 1.0e-12
    taumax  = 1.0e-9  , 1.0e-9
    Nref    = 1.0e16  , 1.0e16
    gamma   = 1       , 1
    Talpha  = -1.5    , -1.5
    Etrap   = 0.0
}

Auger:
{
    A_n = 2.8e-31 , 9.9e-32
    B_n = -9.9e-31 , -2.2e-31
}

ThermalConductivity:
{
    kappa = 0.02
}

SpecificHeat:
{
    rho = 2.0
    c_p = 700.0
}

}

