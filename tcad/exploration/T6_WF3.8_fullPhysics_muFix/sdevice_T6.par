* Trial T6: WF=3.8 + full physics + mu_h fix
* Full physics: Fermi + Thermo + eQP + SRH + Auger

Material = "CNT_thin_film" {

Epsilon
{
    epsilon = 4.0
}

Bandgap
{
    Chi0    = 4.0
    Bgn2Chi = 0.5
    Eg0     = 0.50
    alpha   = 0.0
    beta    = 0.0
    alpha2  = 0.0
    beta2   = 0.0
